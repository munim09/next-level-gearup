model User {
   id String @id @default(uuid()) 
   name String @db.VarChar(255)
   email String @unique
   password String
   activeStatus ActiveStatus @default(ACTIVE)
   role Role @default(CUSTOMER)
   createdAt DateTime @default(now())
   updatedAt DateTime @updatedAt
   profile Profile?    
   
   gears Gear[]
   
   reviews Review[]


  customerOrders RentalOrder[] @relation("Customer")
  providerOrders RentalOrder[] @relation("Provider")
   @@map("users")
}

