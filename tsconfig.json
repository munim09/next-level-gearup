{
    "compilerOptions": {
        "outDir": "./dist",
        "module": "esnext",
        // "moduleResolution": "bundler",
        "target": "esnext",
        "sourceMap": true,
        "declaration": true,
        "declarationMap": true,
        "noUncheckedIndexedAccess": true,
        "strict": true,
        "isolatedModules": true,
        "noUncheckedSideEffectImports": true,
        "moduleDetection": "force",
        "skipLibCheck": true
    },
    // "include": ["src/**/*"],
    "exclude": ["node_modules", "dist"]
}
